{
	"manifest_version":	3,
	"name":			"Daimond Hands",
	"version":		"0.1.0",
	"description":		"Lets Daimond operate a real site in a real tab, in your browser, with your session. No credential ever leaves the device.",

	"key": "",

	"background": {
		"service_worker":	"background.js"
	},

	"permissions": [
		"scripting",
		"tabs",
		"activeTab",
		"storage"
	],

	"optional_host_permissions": [
		"*://*/*",
		"<all_urls>"
	],

	"externally_connectable": {
		"matches": [
			"https://daimond.oxedyne.com/*",
			"http://127.0.0.1:8777/*",
			"http://localhost:8777/*"
		]
	},

	"content_scripts": [
		{
			"matches": [
				"https://daimond.oxedyne.com/*",
				"http://127.0.0.1:8777/*",
				"http://localhost:8777/*"
			],
			"js":			["announce.js"],
			"run_at":		"document_start"
		}
	],

	"action": {
		"default_title":	"Daimond Hands",
		"default_popup":	"popup.html"
	}
}
