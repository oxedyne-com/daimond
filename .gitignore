# Browser wasm harness: build output and headless-test scratch.
# Proven headlessly, not part of the crate build.
/wasmtest/

# wasm-pack build output for the browser UI (regenerated from source).
/www/pkg/

# Vendored wasm tools (Typst compiler + fonts, etc.).  These are large
# downloadable artefacts served at runtime, not committed to the repo
# (they become signed tool-library/registry downloads).
/www/vendor/

# Native build output.
/target/

# The Daimond Hands signing key never belongs in the repo.
*.pem

# The operator-console token is a live secret: created per-deployment, never
# committed. Production writes its own; this dev token stays local.
/gateway/keys/admin_token.txt
gateway/o3db.stale.*/

# Browser test harness scratch: screenshots, provider logs, and the
# per-run audit scripts/results. The reusable harness itself is kept.
/dev/shots/
/dev/*.log
/dev/*.out
/dev/audit_*.mjs
/dev/audit_result_*.json
/dev/*.out

# Local gateway run log.
/gateway/gateway.out

# Local test secrets (API keys) — never committed.
/dev/.secrets/

# The local gateway store, and the copies taken while repairing it.
/gateway/o3db*

# Landing/mobile screenshot scratch.
/shots/

# Research agents once downloaded network pricelists in here; keep them out.
gateway/*.pdf
